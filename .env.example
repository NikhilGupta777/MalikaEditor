# Application Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Session Configuration
# Generate a secure random string for production
SESSION_SECRET="your-secure-session-secret-here"

# AI Service API Keys
# Get your keys from the respective service providers
GEMINI_API_KEY="your-gemini-api-key"
ASSEMBLYAI_API_KEY="your-assemblyai-api-key"
AI_INTEGRATIONS_GEMINI_API_KEY="your-integration-gemini-api-key"

# Media Service API Keys
PEXELS_API_KEY="your-pexels-api-key"
FREEPIK_API_KEY="your-freepik-api-key"

# Optional Configuration
# MAX_VIDEO_DURATION_SECONDS=1800
# SELF_REVIEW_MAX_VIDEO_MB=50
# FILE_STORAGE_TYPE=local
# GCS_BUCKET_NAME=your-bucket-name
# UPLOADS_PATH=/path/to/uploads
# LOG_FILE=/path/to/log.txt
